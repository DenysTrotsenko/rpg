{
  "compileOnSave": false,
  "compilerOptions": {
    "experimentalDecorators": true,
    "baseUrl": "./",
    "declaration": false,
    "downlevelIteration": true,
    "importHelpers": true,
    "moduleResolution": "node",
    "outDir": "./dist/out-tsc",
    "sourceMap": true,
    "target": "es2015",
    "module": "es2020",
    "lib": [
      "es2018",
      "dom"
    ],
    "paths": {
      "@shared": [
        "projects/std/src/public-api",
        "dist/std/std",
        "dist/std"
      ],
      "@grim-and-perilous/*": ["projects/srd/grim-and-perilous/*"],
      "@flames-of-freedom-1e/*": ["projects/srd/flames-of-freedom-1e/*"],
      "@ti/*": ["projects/anno-1800/src/*"]
    }
  }
}
