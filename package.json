{
  "name": "rpg",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "forbidden-lands:test": "ng test --project=forbidden-lands",
    "forbidden-lands:start": "ng serve --project=forbidden-lands",
    "forbidden-lands:build": "ng build --configuration=production --project=forbidden-lands",
    "forbidden-lands:watch": "ng build --project=forbidden-lands --watch",
    "forbidden-lands:deploy": "cd projects/forbidden-lands && firebase deploy",
    "wfrp4:test": "ng test --project=wfrp4",
    "wfrp4:start": "ng serve --project=wfrp4",
    "wfrp4:build": "ng build --configuration=production --project=wfrp4",
    "wfrp4:watch": "ng build --project=wfrp4 --watch",
    "wfrp4:deploy": "cd projects/wfrp4 && firebase deploy",
    "imc:test": "ng test --project=imperium-maledictum-console",
    "imc:start": "ng serve --project=imperium-maledictum-console",
    "imc:build": "ng build --configuration=production --project=imperium-maledictum-console",
    "imc:watch": "ng build --project=imperium-maledictum-console --watch",
    "imc:deploy": "cd projects/imperium-maledictum-console && firebase deploy",
    "im:test": "ng test --project=imperium-maledictum",
    "im:start": "ng serve --project=imperium-maledictum",
    "im:start:hmr": "ng serve --hmr --project=imperium-maledictum",
    "im:build": "ng build --configuration=production --project=imperium-maledictum",
    "im:watch": "ng build --project=imperium-maledictum --watch",
    "im:deploy": "cd projects/imperium-maledictum && firebase deploy",
    "im:deploy-functions": "cd projects/imperium-maledictum/functions && npm run build && npm run deploy",
    "im:emulator": "cd projects/imperium-maledictum/functions && npm run serve",
    "im:functions:build:watch": "cd projects/imperium-maledictum/functions && npm run build:watch"
  },
