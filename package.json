{
  "name": "rpg",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "test:std": "ng test --project=std",
    "start:std": "ng serve --project=std",
    "start:std:hmr": "ng serve --hmr --project=std",
    "build:std": "ng build --configuration=production --project=std",
    "start:im": "ng serve --project=imperium-maledictum",
    "start:im:hmr": "ng serve --hmr --project=imperium-maledictum",
    "build:im": "ng build --configuration=production --project=imperium-maledictum",
    "watch:im": "ng build --project=imperium-maledictum --watch",
    "deploy:im": "cd projects/imperium-maledictum && firebase deploy",
    "deploy-functions:im": "cd projects/imperium-maledictum && firebase deploy --only functions",
    "emulator:im": "cd projects/imperium-maledictum && firebase emulators:start --only functions",
    "start:ti": "ng serve --project=anno-1800",
    "start:ti:hmr": "ng serve --hmr --project=anno-1800",
    "build:ti": "ng build --configuration=production --project=anno-1800",
    "watch:ti": "ng build --project=anno-1800 --watch",
    "deploy:ti": "cd projects/anno-1800 && firebase deploy",
    "deploy-functions:ti": "cd projects/anno-1800 && firebase deploy --only functions",
    "emulator:ti": "cd projects/anno-1800 && firebase emulators:start --only functions",
    "rpg:stats": "webpack-bundle-analyzer projects/anno-1800/dist/*/stats.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^14.3.0",
    "@angular/cdk": "^14.2.7",
    "@angular/common": "^14.3.0",
    "@angular/compiler": "^14.3.0",
    "@angular/core": "^14.3.0",
    "@angular/fire": "^7.4.1",
    "@angular/forms": "^14.3.0",
    "@angular/material": "^14.2.7",
    "@angular/platform-browser": "^14.3.0",
    "@angular/platform-browser-dynamic": "^14.3.0",
    "@angular/router": "^14.3.0",
    "@firebase/logger": "^0.3.4",
    "cors": "^2.8.5",
    "firebase": "^9.1.0",
    "firebase-admin": "^11.0.1",
    "firebase-functions": "^3.23.0",
    "rxjs": "~7.5.6",
    "tslib": "^2.3.1",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^14.2.11",
    "@angular/cli": "^14.2.11",
    "@angular/compiler-cli": "^14.3.0",
    "@types/cors": "^2.8.8",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "^3.9.1",
    "@typescript-eslint/parser": "^3.8.0",
    "codelyzer": "^6.0.0",
    "eslint": "^7.6.0",
    "eslint-plugin-import": "^2.22.0",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.3.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "ng-packagr": "^14.2.2",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~4.8.4",
    "webpack-bundle-analyzer": "^4.4.2"
  }
}
