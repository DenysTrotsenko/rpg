{
  "name": "rpg",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "test:shared": "ng test --project=shared-library",
    "start:shared": "ng serve --project=shared-library",
    "build:shared": "ng build --configuration=production --project=shared-library",
    "start:shadowrun": "ng serve --project=shadowrun",
    "build:shadowrun": "ng build --configuration=production --project=shadowrun",
    "watch:shadowrun": "ng build --project=shadowrun --watch",
    "deploy:shadowrun": "cd projects/shadowrun && firebase deploy",
    "deploy-functions:shadowrun": "cd projects/shadowrun && firebase deploy --only functions",
    "emulator:shadowrun": "cd projects/shadowrun && firebase emulators:start --only functions"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "~12.2.5",
    "@angular/cdk": "^12.2.5",
    "@angular/common": "~12.2.5",
    "@angular/compiler": "~12.2.5",
    "@angular/core": "~12.2.5",
    "@angular/fire": "^7.0.4",
    "@angular/forms": "~12.2.5",
    "@angular/material": "^12.2.5",
    "@angular/platform-browser": "~12.2.5",
    "@angular/platform-browser-dynamic": "~12.2.5",
    "@angular/router": "~12.2.5",
    "cors": "^2.8.5",
    "firebase": "^9.1.0",
    "firebase-admin": "^9.11.1",
    "firebase-functions": "^3.15.7",
    "rxjs": "~6.6.7",
    "tslib": "^2.3.1",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~12.2.5",
    "@angular/cli": "~12.2.5",
    "@angular/compiler-cli": "~12.2.5",
    "@types/cors": "^2.8.8",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "^3.9.1",
    "@typescript-eslint/parser": "^3.8.0",
    "codelyzer": "^6.0.0",
    "eslint": "^7.6.0",
    "eslint-plugin-import": "^2.22.0",
    "firebase-functions-test": "^0.2.0",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~6.3.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "ng-packagr": "^12.2.1",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "tslint": "~6.1.0",
    "typescript": "~4.3.5"
  }
