{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "chronicles-of-darkness": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "style": "scss"
        }
      },
      "root": "projects/chronicles-of-darkness",
      "sourceRoot": "projects/chronicles-of-darkness/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "projects/chronicles-of-darkness/dist",
            "index": "projects/chronicles-of-darkness/src/index.html",
            "main": "projects/chronicles-of-darkness/src/main.ts",
            "polyfills": "projects/chronicles-of-darkness/src/polyfills.ts",
            "tsConfig": "projects/chronicles-of-darkness/tsconfig.app.json",
            "aot": true,
            "assets": [
              "projects/chronicles-of-darkness/src/favicon.ico",
              "projects/chronicles-of-darkness/src/assets"
            ],
            "styles": [
              "projects/shared-library/src/index.scss",
              "projects/chronicles-of-darkness/src/styles.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/shared-library/src/styles/"
              ]
            },
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/chronicles-of-darkness/src/environments/environment.ts",
                  "with": "projects/chronicles-of-darkness/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "chronicles-of-darkness:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "chronicles-of-darkness:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "chronicles-of-darkness:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/chronicles-of-darkness/src/test.ts",
            "polyfills": "projects/chronicles-of-darkness/src/polyfills.ts",
            "tsConfig": "projects/chronicles-of-darkness/tsconfig.spec.json",
            "karmaConfig": "projects/chronicles-of-darkness/karma.conf.js",
            "assets": [
              "projects/chronicles-of-darkness/src/favicon.ico",
              "projects/chronicles-of-darkness/src/assets"
            ],
            "styles": [
              "projects/shared-library/src/index.scss",
              "projects/chronicles-of-darkness/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "projects/chronicles-of-darkness/tsconfig.app.json",
              "projects/chronicles-of-darkness/tsconfig.spec.json",
              "projects/chronicles-of-darkness/e2e/tsconfig.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "projects/chronicles-of-darkness/e2e/protractor.conf.js",
            "devServerTarget": "chronicles-of-darkness:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "chronicles-of-darkness:serve:production"
            }
          }
        }
      }
    },
    "shared-library": {
      "projectType": "library",
      "root": "projects/shared-library",
      "sourceRoot": "projects/shared-library/src",
