{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "std": {
      "projectType": "library",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "style": "scss"
        }
      },
      "root": "projects/std",
      "sourceRoot": "projects/std/src",
      "prefix": "std",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "tsConfig": "projects/std/tsconfig.lib.json",
            "project": "projects/std/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/std/tsconfig.lib.prod.json"
            }
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/std/src/test.ts",
            "tsConfig": "projects/std/tsconfig.spec.json",
            "karmaConfig": "projects/std/karma.conf.js"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "projects/std/tsconfig.lib.json",
              "projects/std/tsconfig.spec.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        }
      }
    },
    "shadowrun": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "style": "scss"
        }
      },
      "root": "projects/shadowrun",
      "sourceRoot": "projects/shadowrun/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "projects/shadowrun/public",
            "index": "projects/shadowrun/src/index.html",
            "main": "projects/shadowrun/src/main.ts",
            "polyfills": "projects/shadowrun/src/polyfills.ts",
            "tsConfig": "projects/shadowrun/tsconfig.app.json",
            "assets": [
              "projects/shadowrun/src/favicon.ico",
              "projects/shadowrun/src/assets"
            ],
            "styles": [
              "projects/shadowrun/src/styles.scss",
              "projects/std/src/index.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/std/src/styles/"
              ]
            },
            "scripts": [],
            "vendorChunk": true,
            "extractLicenses": false,
            "buildOptimizer": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/shadowrun/src/environments/environment.ts",
                  "with": "projects/shadowrun/src/environments/environment.prod.ts"
                }
              ],
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "10kb"
                }
              ]
            }
          },
          "defaultConfiguration": ""
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "shadowrun:build"
          },
          "configurations": {
            "production": {
              "browserTarget": "shadowrun:build:production"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "shadowrun:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/shadowrun/src/test.ts",
            "polyfills": "projects/shadowrun/src/polyfills.ts",
            "tsConfig": "projects/shadowrun/tsconfig.spec.json",
            "karmaConfig": "projects/shadowrun/karma.conf.js",
            "assets": [
              "projects/shadowrun/src/favicon.ico",
              "projects/shadowrun/src/assets"
            ],
            "styles": [
              "projects/shadowrun/src/styles.scss"
            ],
            "scripts": []
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "projects/shadowrun/tsconfig.app.json",
              "projects/shadowrun/tsconfig.spec.json",
              "projects/shadowrun/e2e/tsconfig.json"
            ],
            "exclude": [
              "**/node_modules/**"
            ]
          }
        },
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "projects/shadowrun/e2e/protractor.conf.js",
            "devServerTarget": "shadowrun:serve"
          },
          "configurations": {
            "production": {
              "devServerTarget": "shadowrun:serve:production"
            }
          }
        }
      }
    },
    "blades-in-the-dark": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "changeDetection": "OnPush",
          "style": "scss"
        },
        "@schematics/angular:application": {
          "strict": true
        }
      },
      "root": "projects/blades-in-the-dark",
      "sourceRoot": "projects/blades-in-the-dark/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/blades-in-the-dark",
            "index": "projects/blades-in-the-dark/src/index.html",
            "main": "projects/blades-in-the-dark/src/main.ts",
            "polyfills": "projects/blades-in-the-dark/src/polyfills.ts",
            "tsConfig": "projects/blades-in-the-dark/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/blades-in-the-dark/src/favicon.ico",
              "projects/blades-in-the-dark/src/assets"
            ],
            "styles": [
              "projects/std/src/index.scss",
              "projects/blades-in-the-dark/src/styles.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "projects/std/src/styles/"
              ]
            },
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/blades-in-the-dark/src/environments/environment.ts",
                  "with": "projects/blades-in-the-dark/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "blades-in-the-dark:build:production"
            },
            "development": {
              "browserTarget": "blades-in-the-dark:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "blades-in-the-dark:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/blades-in-the-dark/src/test.ts",
            "polyfills": "projects/blades-in-the-dark/src/polyfills.ts",
            "tsConfig": "projects/blades-in-the-dark/tsconfig.spec.json",
            "karmaConfig": "projects/blades-in-the-dark/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/blades-in-the-dark/src/favicon.ico",
              "projects/blades-in-the-dark/src/assets"
            ],
            "styles": [
              "projects/blades-in-the-dark/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "defaultProject": "std",
  "cli": {
    "analytics": false
  }
}
